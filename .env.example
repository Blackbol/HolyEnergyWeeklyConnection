# Copy this file to .env and fill in your credentials.
# Never commit the .env file.

HOLY_EMAIL=your.email@example.com
HOLY_PASSWORD=your_password_here

# Session cookie extracted from your browser after a manual login.
# Valid for 1 year — extract it once, renew annually.
#
# How to get it:
#   1. Log in to https://fr.holy.com in your browser (Chrome/Brave/Firefox)
#   2. Open DevTools → F12
#   3. Go to: Application → Storage → Cookies → https://fr.holy.com
#   4. Find the cookie named "_shopify_essential"
#   5. Copy the entire Value column (a long string starting with :AZ...)
#   6. Paste it below (keep it on ONE line, no spaces)
HOLY_SHOPIFY_COOKIE=:AZ68...paste_the_full_value_here...

# Optional: connection timeout in seconds (default: 30)
HOLY_TIMEOUT=30

# Optional: log level — PROD (messages lisibles), INFO (technique), DEBUG (tout), WARNING, ERROR
LOG_LEVEL=PROD
